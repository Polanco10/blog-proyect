{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "moduleResolution": "node",
        "types": ["node"],
        "noEmit": false
    },
    "include": ["src/**/*", "app.js", "server.js", "**/*.ts", "!node_modules/**/*"],
    "exclude": ["node_modules", "node_modules/**", "dist/**", "tests/**", "**/node_modules", "**/node_modules/**"],
    "ts-node": {
        "esm": false
    }
}
