{
    "name": "tech-blog-backend",
    "version": "1.0.0",
    "description": "blog api",
    "main": "app.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "NODE_ENV=development npx tsx server.js",
        "prod": "NODE_ENV=production npx tsx server.js",
        "debug": "ndb server.js",
        "build": "tsc",
        "test": "jest --forceExit --detectOpenHandles",
        "test:verbose": "jest --forceExit --detectOpenHandles --verbose",
        "lint": "eslint . --ext .js,.ts",
        "lint:fix": "eslint . --ext .js,.ts --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "seed:resume": "npx tsx data/seed-resume.ts",
        "seed:resume:reset": "npx tsx data/seed-resume.ts --reset",
        "seed:articles": "npx tsx data/seed-articles.ts",
        "seed:articles:reset": "npx tsx data/seed-articles.ts --reset",
        "seed:quicktips": "npx tsx data/seed-quicktips.ts",
        "seed:quicktips:reset": "npx tsx data/seed-quicktips.ts --reset",
        "migrate:published": "npx tsx data/migrate-published.ts",
        "prepare": "husky"
    },
    "author": "Diego Polanco",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.5",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.2.0",
        "helmet": "^7.1.0",
        "hpp": "^0.2.3",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.3.2",
        "morgan": "^1.10.0",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.1",
        "nodemon": "^3.1.14",
        "sharp": "^0.34.5",
        "swagger-ui-express": "^5.0.0",
        "validator": "^13.11.0",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "xss-clean": "^0.1.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/hpp": "^0.2.7",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mongoose": "^5.11.96",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.5.0",
        "@types/nodemailer": "^7.0.11",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "eslint": "^8.57.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-jsx-a11y": "^6.8.0",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-react": "^7.34.1",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "mongodb-memory-server": "^11.0.1",
        "prettier": "^3.2.5",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "lint-staged": {
        "*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    }
}
